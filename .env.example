# --- Azure Speech ---
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=
AZURE_SPEECH_LANGUAGE=pt-BR
AZURE_SPEECH_FALLBACK_LANGUAGES=en-US,es-ES

# --- Azure OpenAI ---
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_DEPLOYMENT=
AZURE_OPENAI_API_VERSION=2024-10-21

# --- Relatório ---
# local | hybrid | azure
REPORT_MODE=local

# --- LGPD (Lei 13.709/2018) ---
# Modo estrito: exige consentimento explícito por caso para processamento.
LGPD_STRICT_MODE=true
LGPD_REQUIRE_EXPLICIT_CONSENT=true

# Permite envio de dados para serviços Microsoft/Azure quando houver consentimento.
LGPD_ALLOW_AZURE_SPEECH=true
LGPD_ALLOW_AZURE_OPENAI=true

# Minimização de dados enviados a terceiros.
LGPD_ANONYMIZE_EXTERNAL_PAYLOADS=true
LGPD_MAX_TRANSCRIPT_CHARS_AZURE=4000

# Retenção recomendada para artefatos de casos demo (dias).
LGPD_DATA_RETENTION_DAYS=30
LGPD_PROCESSING_PURPOSE=triagem_multimodal_apoio_clinico_pesquisa
