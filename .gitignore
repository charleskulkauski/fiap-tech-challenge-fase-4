# --- Python / ambiente ---
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
.env

# --- IDE / SO ---
.vscode/
.idea/
.cursor/
Thumbs.db
.DS_Store

# --- Pesos e checkpoints (ML) ---
*.pt
*.pth
*.onnx
*.task
*.h5
*.pkl
*.safetensors
yolov8*.pt

# YOLO / treino local (codigo .py em models/ continua versionado)
models/yolo_instruments/weights/
models/yolo_instruments/runs/
models/yolo_instruments/datasets/
models/action_events/runs/
models/pose_detect/*.task

# Hugging Face: ignorar checkpoints; manter manifest + README
hf_models/*
!hf_models/manifest.json
!hf_models/README.md

# Runs Ultralytics (raiz do projeto)
runs/

# --- Datasets YOLO (baixar: scripts/download_hf_assets.py --datasets) ---
data/gynsurg/
data/medical_fiap-tech-challenge.yolov8/
data/bleeding_fiap-tech-challenge.yolov8/
data/combined_medical_bleeding.yolov8/
data/gynsurg_instruments_detection.yolov8/

# Imagens, labels e splits de datasets (qualquer pasta data/)
data/**/train/
data/**/valid/
data/**/test/
data/**/images/
data/**/labels/
data/**/*.png
data/**/*.jpg
data/**/*.jpeg
data/**/*.webp
data/**/*.bmp
data/**/*.tif
data/**/*.zip

# --- Midia e artefatos clinicos ---
data/videos/
data/transcripts/
data/audio_analysis/
data/reports/

# Casos demo: insumos, saidas processadas e relatorios (LGPD + tamanho)
data/demo/**/inputs/
data/demo/**/outputs/
data/demo/**/reports/

# Metadados leves de demo (case_meta.json, status.json na raiz do caso)
